#ifndef __PROJECT_SECRETS_H_
#define __PROJECT_SECRETS_H_

/*
 * Copy this file to project_secrets.h before building, then fill in your
 * local Wi-Fi and cloud service credentials. The real file is ignored by Git.
 */

#define PROJECT_WIFI_SSID             "YOUR_WIFI_SSID"
#define PROJECT_WIFI_PASSWORD         "YOUR_WIFI_PASSWORD"

#define PROJECT_ASR_BAIDU_API_KEY     "YOUR_BAIDU_API_KEY"
#define PROJECT_ASR_BAIDU_SECRET_KEY  "YOUR_BAIDU_SECRET_KEY"

#define PROJECT_TTS_APP_ID            "YOUR_TTS_APP_ID"
#define PROJECT_TTS_ACCESS_KEY        "YOUR_TTS_ACCESS_KEY"
#define PROJECT_TTS_RESOURCE_ID       "seed-tts-2.0"
#define PROJECT_TTS_SPEAKER           "YOUR_TTS_SPEAKER"

#endif
